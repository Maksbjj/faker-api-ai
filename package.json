{
  "name": "pw-ai-faker-api",
  "version": "1.0.0",
  "description": "Playwright API test framework for FakeRESTApi",
  "scripts": {
    "check": "npm run format && npm run lint && npm run tsc:check",
    "format": "npx prettier --write .",
    "lint": "npx eslint . --max-warnings=0",
    "tsc:check": "npx tsc --noEmit --pretty --strict",
    "test": "npx playwright test",
    "test:headed": "npm run test -- --headed",
    "test:ui-mode": "npm run test -- --ui",
    "show-report": "npx playwright show-report"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@faker-js/faker": "^9.3.0",
    "@playwright/test": "^1.49.1",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "eslint-plugin-playwright": "^2.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}
